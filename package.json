{
  "name": "number-detector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "start": "node server/index.js",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "node --watch server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "lint": "eslint .",
    "evaluate": "node scripts/evaluate_detection.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "cors": "latest",
    "express": "latest",
    "jpeg-js": "^0.4.4",
    "multer": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sharp": "^0.35.3",
    "tesseract.js": "^7.0.0",
    "pngjs": "^7.0.0",
    "react": "latest",
    "react-dom": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "eslint": "latest",
    "globals": "latest"
  }
}
